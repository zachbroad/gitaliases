<div class="space-y-8">
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Git Aliases</h2>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">Discover and share useful Git aliases from the community</p>
    </div>
    <% if user_signed_in? %>
      <div class="mt-4 sm:mt-0 flex space-x-3">
        <%= link_to "Add New Alias", new_alias_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% else %>
      <div class="mt-4 sm:mt-0">
        <%= link_to "Sign Up", new_user_registration_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>
  </div>

  <!-- Search and Filter Interface -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <%= form_with url: root_path, method: :get, local: true, class: "space-y-4" do |form| %>
      <div class="mb-3">
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Search across alias names, descriptions, and git commands. Try searching for "status", "commit", or "branch".
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Search Input -->
        <div class="flex-1">
          <%= form.text_field :search, value: params[:search], 
              placeholder: "Search by name, description, or git command...", 
              class: "block w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm p-3" %>
        </div>
        
        <!-- Tag Filter -->
        <div class="flex-1">
          <%= form.text_field :tags, value: params[:tags], 
              placeholder: "Filter by tags (comma-separated)...", 
              class: "block w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm p-3" %>
        </div>
        
        <!-- Search Button -->
        <div class="flex space-x-2">
          <%= form.submit "Search", class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <% if params[:search].present? || params[:tags].present? %>
            <%= link_to "Clear", root_path, class: "inline-flex items-center px-6 py-3 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-lg text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <% end %>
        </div>
      </div>
    <% end %>
    
    <!-- Popular Tags -->
    <% if @popular_tags.any? %>
      <div class="mt-4">
        <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Popular tags:</p>
        <div class="flex flex-wrap gap-2">
          <% @popular_tags.each do |tag| %>
            <%= link_to root_path(tags: tag.name), class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-800 dark:text-indigo-200 hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors duration-200" do %>
              <%= tag.name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Search Results Summary -->
  <% if has_active_filters? %>
    <div class="bg-blue-50 dark:bg-blue-900 border-l-4 border-blue-400 dark:border-blue-500 p-4 rounded-r-lg">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-blue-400 dark:text-blue-300 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p class="text-sm font-medium text-blue-800 dark:text-blue-200">
              Showing <%= pluralize(@total_count, 'result') %> for <%= search_summary_text %>
            </p>
          </div>
        </div>
        <div class="flex items-center space-x-2">
          <%= link_to root_path, class: "inline-flex items-center px-3 py-1.5 border border-blue-300 dark:border-blue-600 text-xs font-medium rounded-md text-blue-700 dark:text-blue-200 bg-white dark:bg-blue-800 hover:bg-blue-50 dark:hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
            <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Clear filters
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @aliases.any? %>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @aliases.each do |alias_item| %>
        <%= render "aliases/alias_card", alias_item: alias_item %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No aliases found</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Be the first to share a Git alias with the community.</p>
      <% if user_signed_in? %>
        <div class="mt-6">
          <%= link_to "Add Your First Alias", new_alias_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% else %>
        <div class="mt-6">
          <%= link_to "Sign Up to Add Aliases", new_user_registration_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
