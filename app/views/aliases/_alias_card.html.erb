<%= turbo_frame_tag "alias_#{alias_item.id}" do %>
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow-sm rounded-lg border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow duration-200">
    <div class="px-6 py-5">
      <div class="flex items-center justify-between">
        <%= link_to alias_item, data: { turbo_frame: "_top" }, class: "text-lg font-semibold text-gray-900 dark:text-white truncate hover:text-indigo-600 dark:hover:text-indigo-400" do %>
          <%= alias_item.name %>
        <% end %>
        
        <!-- Score in header -->
        <div class="flex items-center space-x-2">
          <% unless current_user && alias_item.user == current_user %>
            <% if current_user %>
              <% user_vote = alias_item.user_vote(current_user) %>
              <% liked = user_vote&.vote_type == "like" %>
              <% disliked = user_vote&.vote_type == "dislike" %>
            <% else %>
              <% ip_vote = alias_item.ip_vote(request.remote_ip) %>
              <% liked = ip_vote&.vote_type == "like" %>
              <% disliked = ip_vote&.vote_type == "dislike" %>
            <% end %>

            <%= button_to vote_alias_path(alias_item.id), params: { vote_type: "like" }, data: { turbo: true }, method: :post, class: "p-1 rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors #{liked ? 'text-blue-500' : 'text-gray-400 hover:text-blue-500'}" do %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
              </svg>
            <% end %>
          <% end %>
          
          <span class="text-xl font-bold text-gray-900 dark:text-white">
            <%= alias_item.score %>
          </span>
          
          <% unless current_user && alias_item.user == current_user %>
            <%= button_to vote_alias_path(alias_item.id), params: { vote_type: "dislike" }, method: :post, class: "p-1 rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors #{disliked ? 'text-orange-500' : 'text-gray-400 hover:text-orange-500'}" do %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <p class="mt-3 text-sm text-gray-600 dark:text-gray-300 line-clamp-2">
        <%= truncate(alias_item.description, length: 150) %>
      </p>
      
      <% if alias_item.tags.any? %>
        <div class="mt-2 flex flex-wrap gap-1">
          <% alias_item.tags.each do |tag| %>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-800 dark:text-indigo-200">
              <%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>

      <div class="mt-4">
        <div class="bg-gray-50 dark:bg-gray-700 rounded-md p-3 border border-gray-200 dark:border-gray-600">
          <code class="text-sm font-mono text-gray-800 dark:text-gray-200 break-all">
            <%= alias_item.display_code %>
          </code>
        </div>
      </div>

      <div class="mt-4 flex justify-between items-center">
        <% if alias_item.user %>
          <%= link_to profile_path(alias_item.user.email.split('@').first), data: {turbo_frame: "_top"}, class: "text-xs text-gray-500 dark:text-gray-400 underline hover:text-indigo-600 dark:hover:text-indigo-400" do %>
            by <%= alias_item.user.email.split('@').first %>
          <% end %>
        <% else %>
          <span class="text-xs text-gray-500 dark:text-gray-400">by anonymous</span>
        <% end %>

        <div class="flex space-x-2">
          <% if current_user && alias_item.user == current_user %>
            <%= link_to edit_alias_path(alias_item), data: { turbo_frame: "_top" }, class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-600 text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              ✏️ Edit
            <% end %>

            <%= button_to alias_item, method: :delete, data: { turbo_frame: "_top", confirm: "Are you sure you want to delete this alias?" }, class: "inline-flex items-center px-3 py-1.5 border border-red-300 dark:border-red-600 text-xs font-medium rounded text-red-700 dark:text-red-400 bg-white dark:bg-gray-700 hover:bg-red-50 dark:hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
              🗑️ Delete
            <% end %>
          <% end %>

          <button type="button" 
                  onclick="copyToClipboard('<%= j(alias_item.display_code) %>', this)" 
                  class="copy-btn inline-flex items-center px-2 py-1.5 border border-gray-300 dark:border-gray-600 text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            ▶️ Copy Command
          </button>
          
          <button type="button" 
                  onclick="copyToClipboard('<%= j(alias_item.config_command) %>', this)" 
                  class="copy-btn inline-flex items-center px-2 py-1.5 border border-gray-300 dark:border-gray-600 text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            ⚙️ Copy Config
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>