<%= turbo_frame_tag "alias_#{alias_item.id}" do %>
  <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200 hover:shadow-md transition-shadow duration-200">
    <div class="px-6 py-5">
      <div class="flex items-center justify-between">
        <%= link_to alias_item, data: { turbo_frame: "_top" }, class: "text-lg font-semibold text-gray-900 truncate hover:text-indigo-600" do %>
          <%= alias_item.name %>
        <% end %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <%= alias_item.score %>
        </span>
      </div>

      <p class="mt-3 text-sm text-gray-600 line-clamp-2">
        <%= truncate(alias_item.description, length: 150) %>
      </p>
      
      <% if alias_item.tags.any? %>
        <div class="mt-2 flex flex-wrap gap-1">
          <% alias_item.tags.each do |tag| %>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
              <%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>

      <div class="mt-4">
        <div class="bg-gray-50 rounded-md p-3 border">
          <code class="text-sm font-mono text-gray-800 break-all">
            <%= alias_item.code %>
          </code>
        </div>
      </div>

      <div class="mt-4 flex justify-between items-center">
        <% if alias_item.user %>
          <%= link_to profile_path(alias_item.user.email.split('@').first), data: {turbo_frame: "_top"}, class: "text-xs text-gray-500 underline hover:text-indigo-600" do %>
            by <%= alias_item.user.email.split('@').first %>
          <% end %>
        <% else %>
          <span class="text-xs text-gray-500">by anonymous</span>
        <% end %>

        <div class="flex space-x-2">
          <% if current_user && alias_item.user == current_user %>
            <%= link_to edit_alias_path(alias_item), data: { turbo_frame: "_top" }, class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              ✏️ Edit
            <% end %>

            <%= button_to alias_item, method: :delete, data: { turbo_frame: "_top", confirm: "Are you sure you want to delete this alias?" }, class: "inline-flex items-center px-3 py-1.5 border border-red-300 text-xs font-medium rounded text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
              🗑️ Delete
            <% end %>
          <% else %>
            <% if current_user %>
              <% user_vote = alias_item.user_vote(current_user) %>
              <% liked = user_vote&.vote_type == "like" %>
              <% disliked = user_vote&.vote_type == "dislike" %>
            <% else %>
              <% ip_vote = alias_item.ip_vote(request.remote_ip) %>
              <% liked = ip_vote&.vote_type == "like" %>
              <% disliked = ip_vote&.vote_type == "dislike" %>
            <% end %>

            <%= button_to vote_alias_path(alias_item.id), params: { vote_type: "like" }, data: { turbo: true }, method: :post, class: "inline-flex items-center px-3 py-1.5 border text-xs font-medium rounded focus:outline-none focus:ring-2 focus:ring-offset-2 #{liked ? 'border-indigo-500 bg-indigo-100 text-indigo-700 hover:bg-indigo-200 focus:ring-indigo-500' : 'border-gray-300 text-gray-700 bg-white hover:bg-gray-50 focus:ring-indigo-500'}" do %>
              <%= liked ? "👍 Liked" : "👍 Like" %>
            <% end %>

            <%= button_to vote_alias_path(alias_item.id), params: { vote_type: "dislike" }, method: :post, class: "inline-flex items-center px-3 py-1.5 border text-xs font-medium rounded focus:outline-none focus:ring-2 focus:ring-offset-2 #{disliked ? 'border-red-500 bg-red-100 text-red-700 hover:bg-red-200 focus:ring-red-500' : 'border-gray-300 text-red-700 bg-white hover:bg-red-50 focus:ring-red-500'}" do %>
              <%= disliked ? "👎 Disliked" : "👎 Dislike" %>
            <% end %>
          <% end %>

          <button type="button" 
                  onclick="copyToClipboard('<%= j(alias_item.code) %>', this)" 
                  class="copy-btn inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            📋 Copy
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>