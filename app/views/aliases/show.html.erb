<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-3xl font-bold text-gray-900"><%= @alias.name %></h2>
      <div class="mt-2 flex items-center space-x-2">
        <p class="text-sm text-gray-700">Git alias details</p>
        <% if @alias.user %>
          <span class="text-gray-400">•</span>
          <%= link_to profile_path(@alias.user.email.split('@').first), class: "text-sm text-gray-600 hover:text-indigo-600" do %>
            Shared by <%= @alias.user.email.split('@').first %>
          <% end %>
        <% else %>
          <span class="text-gray-400">•</span>
          <span class="text-sm text-gray-600">Shared by anonymous</span>
        <% end %>
      </div>
    </div>
    <div class="flex space-x-3">
      <%= link_to "Edit", edit_alias_path(@alias), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      <%= link_to "Delete", alias_path(@alias), method: :delete, 
          confirm: "Are you sure you want to delete this alias?",
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-lg border border-gray-200">
    <div class="px-6 py-8">
      <div class="space-y-6">
        <div>
          <dt class="text-sm font-medium text-gray-500">Alias Name</dt>
          <dd class="mt-1 text-lg text-gray-900 font-mono bg-gray-50 px-3 py-2 rounded-md border">
            git <%= @alias.name %>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Description</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <%= @alias.description %>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Git Command</dt>
          <dd class="mt-1">
            <div class="bg-gray-900 text-gray-100 p-4 rounded-md font-mono text-sm">
              <span class="text-green-400">git</span> <%= @alias.code %>
            </div>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Usage Example</dt>
          <dd class="mt-1">
            <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
              <p class="text-sm text-blue-800">
                <span class="font-medium">Instead of:</span> <code class="bg-blue-100 px-2 py-1 rounded">git <%= @alias.code %></code>
              </p>
              <p class="text-sm text-blue-800 mt-2">
                <span class="font-medium">Use:</span> <code class="bg-blue-100 px-2 py-1 rounded">git <%= @alias.name %></code>
              </p>
            </div>
          </dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Installation</dt>
          <dd class="mt-1">
            <div class="bg-gray-50 border border-gray-200 rounded-md p-4">
              <p class="text-sm text-gray-700 mb-2">Add this to your Git configuration:</p>
              <code class="text-sm font-mono text-gray-900 bg-white px-3 py-2 rounded border block">
                git config --global alias.<%= @alias.name %> "<%= @alias.code %>"
              </code>
            </div>
          </dd>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-between">
    <%= link_to "← Back to Aliases", aliases_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    
    <div class="flex space-x-3">
      <%= link_to "Edit Alias", edit_alias_path(@alias), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  </div>
</div>
